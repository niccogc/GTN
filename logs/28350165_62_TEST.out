#     "abalone" "adult" "ai4i" "appliances" "bank" "bike" "breast"
#     "car_evaluation" "concrete" "energy_efficiency" "hearth"
#     "iris" "mushrooms" "obesity" "popularity" "realstate"
#     "seoulBike" "student_dropout" "student_perf" "wine"
#     "winequalityc"
