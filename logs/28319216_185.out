        M_IDX=$((IDV % NUM_MODELS))
        D_IDX=$((IDV / NUM_MODELS))
        echo "Index $i: Dataset=${DATASETS[$D_IDX]}, Model=${MODELS[$M_IDX]}"
    done
    exit 0
fi
