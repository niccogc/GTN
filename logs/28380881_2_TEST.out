# LSBATCH: User input
#!/bin/bash
#BSUB -q hpc
#BSUB -J "Gtn_test[1-22]%20"
#BSUB -W 8:00
#BSUB -n 6
#BSUB -R "rusage[mem=500MB]"
#BSUB -R "span[hosts=1]"
