    "winequalityc"
)

COMPLETED_DATASETS=(
    "abalone" "ai4i" "hearth" "wine" "winequalityc" "bike" "concrete" "energy_efficiency"
    "iris" "realstate" )

# Filter datasets
FILTERED_DATASETS=()
for ds in "${DATASETS[@]}"; do
    skip=false
    for completed in "${COMPLETED_DATASETS[@]}"; do
        if [[ "$ds" == "$completed" ]]; then
            skip=true
            break
        fi
    done

    if ! $skip; then
        FILTERED_DATASETS+=("$ds")
    fi
done

DATASETS=("${FILTERED_DATASETS[@]}")

NUM_MODELS=${#MODELS[@]}
NUM_DATASETS=${#DATASETS[@]}
NUM_EXPERIMENTS=$((NUM_DATASETS * NUM_MODELS))

