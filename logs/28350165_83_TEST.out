# LSBATCH: User input
#!/bin/bash
#BSUB -q hpc
#BSUB -J "ntn_test[1-100]%20"
#BSUB -W 8:00
#BSUB -n 10
#BSUB -R "rusage[mem=750MB]"
#BSUB -R "span[hosts=1]"
