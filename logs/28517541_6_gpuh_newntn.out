# LSBATCH: User input
#!/bin/bash
#BSUB -q gpuh100
#BSUB -J "ntn_grid_missing[1-12]%20"
#BSUB -W 20:00
#BSUB -n 6
#BSUB -R "rusage[mem=750MB]"
#BSUB -R "span[hosts=1]"
#BSUB -o logs/%J_%I_gpuh_newntn.out
#BSUB -e logs/%J_%I_gpuh_newntn.err
