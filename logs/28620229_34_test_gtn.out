source missing_test.env

NUM_EXPERIMENTS=${#COMBINATIONS_GTN[@]}

mkdir -p logs

IDV=$((LSB_JOBINDEX - 1))
read MODEL DATASET <<< "${COMBINATIONS_GTN[$IDV]}"
echo "Test GTN: $MODEL $DATASET"

EXPERIMENT="test_gtn"

