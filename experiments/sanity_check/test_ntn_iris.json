{
  "experiment_name": "test_ntn_iris",
  "dataset": "iris",
  "task": "classification",
  "parameter_grid": {
    "model": ["MPO2", "LMPO2", "MMPO2", "MPO2TypeI", "LMPO2TypeI", "MMPO2TypeI"],
    "L": [3],
    "bond_dim": [2]
  },
  "fixed_params": {
    "batch_size": 64,
    "n_epochs": 1,
    "jitter_start": 1.0,
    "jitter_decay": 0.5,
    "adaptive_jitter": false,
    "patience": 1,
    "min_delta": 1e-05,
    "init_strength": 0.1,
    "reduction_factor": 0.5,
    "seeds": [42]
  },
  "tracker": {
    "backend": "none"
  },
  "output": {
    "results_dir": "sanity_check/results/ntn_iris",
    "save_models": false,
    "save_individual_runs": true
  }
}
