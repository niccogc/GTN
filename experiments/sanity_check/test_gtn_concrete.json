{
  "experiment_name": "test_gtn_concrete",
  "dataset": "concrete",
  "task": "regression",
  "parameter_grid": {
    "model": ["MPO2", "LMPO2", "MMPO2", "MPO2TypeI_GTN", "LMPO2TypeI_GTN", "MMPO2TypeI_GTN"],
    "L": [3],
    "bond_dim": [2]
  },
  "fixed_params": {
    "batch_size": 64,
    "n_epochs": 1,
    "lr": 0.01,
    "patience": 1,
    "min_delta": 1e-05,
    "optimizer": "adamw",
    "init_strength": 0.1,
    "reduction_factor": 0.5,
    "seeds": [42]
  },
  "tracker": {
    "backend": "none"
  },
  "output": {
    "results_dir": "sanity_check/results/gtn_concrete",
    "save_models": false,
    "save_individual_runs": true
  }
