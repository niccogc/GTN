# Run GTN test for LMPO2 on iris (will auto-use best L=3, bond_dim=12)
python run.py +experiment=test_gtn model=lmpo2 dataset=iris
# Run GTN test multirun over all seeds for LMPO2/iris
python run.py --multirun +experiment=test_gtn model=lmpo2 dataset=iris
# Run NTN test for MPO2 on breast
python run.py -m +experiment=test_ntn model=mpo2 dataset=breast
The best config is automatically looked up from conf/best_conf/{gtn,ntn}/{model}.yaml based on the dataset name.
